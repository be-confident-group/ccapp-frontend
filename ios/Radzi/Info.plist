      <dict>
        <key>CFBundleURLSchemes</key>
        <array>
          <string>exp+ccapp-frontend</string>
        </array>
      </dict>
      <dict>
        <key>CFBundleURLSchemes</key>
        <array>
          <string>com.googleusercontent.apps.229488268800-st69okr9atquav65k8du0iov5fpgqsas</string>
        </array>
      </dict>
    </array>
    <key>CFBundleVersion</key>
    <string>1</string>
